# Copie este arquivo para .env e preencha com seus valores
# cp .env.example .env

# ─── Banco de dados 
# Formato: postgresql://USUARIO:SENHA@HOST:PORTA/NOME_DO_BANCO
DATABASE_URL="postgresql://postgres:suasenha@localhost:5432/buscape_travels"

# ─── JWT 
# Gere uma chave secreta forte (ex: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))")
JWT_SECRET="troque-por-uma-chave-secreta-forte-aqui"
JWT_EXPIRES_IN="7d"

# ─── Servidor 
PORT=3333
NODE_ENV=development

# ─── Frontend (para o CORS) 
FRONTEND_URL="http://localhost:5173"
